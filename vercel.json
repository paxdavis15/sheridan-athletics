{
  "version": 2,
  "functions": {
    "api/create-checkout.js": { "memory": 256 },
    "api/webhook.js": { "memory": 256 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://paxdavis15.github.io" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
